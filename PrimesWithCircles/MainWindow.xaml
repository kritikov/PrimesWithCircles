<Window x:Class="PrimesWithCircles.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Primes With Circles" Width="1000" Height="700">
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="230"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <StackPanel Grid.Column="0" Margin="12" VerticalAlignment="Top" >
            <TextBlock Text="Controls" FontWeight="Bold" FontSize="16" Margin="0,0,0,8"/>
            <CheckBox x:Name="AutoModeCheck" Content="Auto mode" IsChecked="True" Margin="0,0,0,6"/>
            <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                <Button x:Name="RotateButton" Content="Rotate" Click="RotateButton_Click" Width="70"/>
                <Button x:Name="PauseBtn" Content="Pause" Click="PauseBtn_Click" Width="70"/>
                <Button Content="Reset" Click="ResetBtn_Click" Width="70"/>

            </StackPanel>

            <TextBlock Text="Speed" Margin="0,6,0,0"/>
            <Slider x:Name="SpeedSlider" Minimum="0.02" Maximum="2.0" Value="1" TickFrequency="0.02" ValueChanged="SpeedSlider_ValueChanged"/>

            <TextBlock Text="Lap counter" Margin="0,12,0,0"/>
            <TextBlock FontSize="28" FontWeight="Bold" Text="{Binding LapCounter}" Margin="0,6,0,0"/>

            <TextBlock Text="Primes" Margin="0,12,0,0"/>
            <TextBlock Text="{Binding Primes}" TextWrapping="Wrap" Height="132" />
            <ScrollViewer VerticalScrollBarVisibility="Auto">
                
            </ScrollViewer>

        </StackPanel>

        <Grid Grid.Column="1" >
            <Canvas x:Name="RotationCanvas" Background="Black">
                <Canvas.LayoutTransform>
                    <ScaleTransform x:Name="ZoomTransform" ScaleX="1" ScaleY="1"/>
                </Canvas.LayoutTransform>
            </Canvas>
        </Grid>
        
    </Grid>
</Window>
